map:rules_000 <http://rdfs.org/ns/void#exampleResource> map:map_DireccionPostal_000, map:map_District_000, map:map_GeometryMobileCollectionPoint_000, map:map_MobileCollectionPoint_000 ;
	rdf:type <http://rdfs.org/ns/void#Dataset> .

map:s_000 rdf:type rr:SubjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/collectionPoint/mobile/{Código de distrito}-{Tipo de vía}-{Nombre de la vía}-{Tipo de número}-{Número}-{Día de la semana}-{Turno}-{Hora de inicio}" .

map:s_001 rdf:type rr:SubjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/address/{Código de distrito}-{Tipo de vía}-{Nombre de la vía}-{Tipo de número}-{Número}" .

map:s_002 rdf:type rr:SubjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/district/{Distrito}" .

map:s_003 rdf:type rr:SubjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/geometry/collectionPoint/mobile/{Código de distrito}-{Tipo de vía}-{Nombre de la vía}-{Tipo de número}-{Número}" .

map:source_000 rml:referenceFormulation ql:CSV ;
	rml:source "dataset-enriquecido-2.csv" ;
	rdf:type rml:LogicalSource ;
	rdfs:label "mobileCollectionPoint-source" .

