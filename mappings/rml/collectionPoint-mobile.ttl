@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix map: <http://mapping.example.com/> .
@prefix ma: <http://www.w3.org/ns/ma-ont#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sd: <http://www.w3.org/ns/sparql-service-description#> .
@prefix schema: <https://schema.org/> .
@prefix waste: <https://w3id.org/def/medioambiente/residuos#> .
@prefix esdir: <https://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#> .
@prefix esadm: <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#> .
@prefix gsp: <http://www.opengis.net/ont/geosparql#> .

map:map_DireccionPostal_000 rml:logicalSource map:source_000 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "DireccionPostal" ;
	rr:predicateObjectMap map:pom_007, map:pom_008, map:pom_009, map:pom_010, map:pom_011, map:pom_012, map:pom_013 ;
	rr:subjectMap map:s_001 .

map:map_District_000 rml:logicalSource map:source_000 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "District" ;
	rr:predicateObjectMap map:pom_014, map:pom_015 ;
	rr:subjectMap map:s_002 .

map:map_GeometryMobileCollectionPoint_000 rml:logicalSource map:source_000 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "GeometryMobileCollectionPoint" ;
	rr:predicateObjectMap map:pom_016, map:pom_017 ;
	rr:subjectMap map:s_003 .

map:map_MobileCollectionPoint_000 rml:logicalSource map:source_000 ;
	rdf:type rr:TriplesMap ;
	rdfs:label "MobileCollectionPoint" ;
	rr:predicateObjectMap map:pom_000, map:pom_001, map:pom_002, map:pom_003, map:pom_004, map:pom_005, map:pom_006 ;
	rr:subjectMap map:s_000 .

map:om_000 rdf:type rr:ObjectMap ;
	rr:constant waste:MobileCollectionPoint ;
	rr:termType rr:IRI .

map:om_001 rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:template "{Día de la semana} {Turno} {Hora de inicio}-{Hora de fin}" ;
	rr:termType rr:Literal .

map:om_002 rml:reference "Residuos admisibles" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:anyURI ;
	rr:termType rr:Literal .

map:om_003 rml:reference "Google Maps" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:anyURI ;
	rr:termType rr:Literal .

map:om_004 rdf:type rr:ObjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/address/{Código de distrito}-{Tipo de vía}-{Nombre de la vía}-{Tipo de número}-{Número}" ;
	rr:termType rr:IRI .

map:om_005 rdf:type rr:ObjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/district/{Distrito}" ;
	rr:termType rr:IRI .

map:om_006 rdf:type rr:ObjectMap ;
	rr:template "https://w3id.org/medioambiente/recurso/residuos/geometry/collectionPoint/mobile/{Código de distrito}-{Tipo de vía}-{Nombre de la vía}-{Tipo de número}-{Número}" ;
	rr:termType rr:IRI .

map:om_007 rdf:type rr:ObjectMap ;
	rr:constant esdir:DireccionPostal ;
	rr:termType rr:IRI .

map:om_008 rml:reference "Dirección" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_009 rml:reference "Dirección auxiliar" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_010 rml:reference "Tipo de vía" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_011 rml:reference "Nombre de la vía" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_012 rml:reference "Tipo de número" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_013 rml:reference "Número" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_014 rdf:type rr:ObjectMap ;
	rr:constant esadm:Distrito ;
	rr:termType rr:IRI .

map:om_015 rml:reference "Distrito" ;
	rdf:type rr:ObjectMap ;
	rr:datatype xsd:string ;
	rr:termType rr:Literal .

map:om_016 rdf:type rr:ObjectMap ;
	rr:constant gsp:Geometry ;
	rr:termType rr:IRI .

map:om_017 rdf:type rr:ObjectMap ;
	rr:datatype gsp:wktLiteral ;
	rr:template "POINT({Longitud (geo)} {Latitud (geo)})" ;
	rr:termType rr:Literal .

map:pm_000 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

map:pm_001 rdf:type rr:PredicateMap ;
	rr:constant schema:openingHours .

map:pm_002 rdf:type rr:PredicateMap ;
	rr:constant waste:admissibleWasteURL .

map:pm_003 rdf:type rr:PredicateMap ;
	rr:constant schema:map .

map:pm_004 rdf:type rr:PredicateMap ;
	rr:constant schema:address .

map:pm_005 rdf:type rr:PredicateMap ;
	rr:constant waste:belongsTo .

map:pm_006 rdf:type rr:PredicateMap ;
	rr:constant gsp:hasGeometry .

map:pm_007 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

map:pm_008 rdf:type rr:PredicateMap ;
	rr:constant esdir:direccion .

map:pm_009 rdf:type rr:PredicateMap ;
	rr:constant waste:secondaryAddress .

map:pm_010 rdf:type rr:PredicateMap ;
	rr:constant waste:streetType .

map:pm_011 rdf:type rr:PredicateMap ;
	rr:constant esdir:nombreDeLaVia .

map:pm_012 rdf:type rr:PredicateMap ;
	rr:constant waste:streetNumberType .

map:pm_013 rdf:type rr:PredicateMap ;
	rr:constant esdir:locatorName .

map:pm_014 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

map:pm_015 rdf:type rr:PredicateMap ;
	rr:constant schema:name .

map:pm_016 rdf:type rr:PredicateMap ;
	rr:constant rdf:type .

map:pm_017 rdf:type rr:PredicateMap ;
	rr:constant gsp:asWKT .

map:pom_000 rdf:type rr:PredicateObjectMap ;
	rr:objectMap map:om_000 ;
	rr:predicateMap map:pm_000 .

map:pom_001 rdf:type rr:PredicateObjectMap ;
	rr:objectMap map:om_001 ;
	rr:predicateMap map:pm_001 .

map:pom_002 rdf:type rr:PredicateObjectMap ;
	rr:objectMap map:om_002 ;
	rr:predicateMap map:pm_002 .

map:pom_003 rdf:type rr:PredicateObjectMap ;
	rr:objectMap map:om_003 ;
	rr:predicateMap map:pm_003 .

map:pom_004 rdf:type rr:PredicateObjectMap ;
	rr:objectMap map:om_004 ;
	rr:predicateMap map:pm_004 .

