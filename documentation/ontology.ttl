@prefix : <https://w3id.org/def/medioambiente/residuos#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/def/medioambiente/residuos#> .

<https://w3id.org/def/medioambiente/residuos#> rdf:type owl:Ontology ;
                                                owl:versionIRI <https://w3id.org/def/medioambiente/residuos/1.0> ;
                                                <http://purl.org/dc/terms/created> "2026-04-01"^^xsd:date ;
                                                <http://purl.org/dc/terms/creator> "Laura Gilgado Romero" ;
                                                <http://purl.org/dc/terms/description> "Ontology that describes the elements associated with waste management, including facilities, containers and collection points."@en ,
                                                                                       "Ontología que describe los elementos asociados a la gestión de residuos, incluyendo centros, contenedores y puntos limpios."@es ;
                                                <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                <http://purl.org/dc/terms/title> "Ontology for the representation of waste management"@en ,
                                                                                 "Ontología para la representación de la gestión de residuos"@es ;
                                                <http://purl.org/vocab/vann/preferredNamespacePrefix> "waste" ;
                                                <http://purl.org/vocab/vann/preferredNamespaceUri> <https://w3id.org/def/medioambiente/residuos#> ;
                                                owl:versionInfo "1.0" ;
                                                <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.opengis.net/ont/geosparql#wktLiteral
<http://www.opengis.net/ont/geosparql#wktLiteral> rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.opengis.net/ont/geosparql#hasGeometry
<http://www.opengis.net/ont/geosparql#hasGeometry> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.opengis.net/ont/geosparql#Feature> ;
                                                   rdfs:range <http://www.opengis.net/ont/geosparql#Geometry> ;
                                                   rdfs:label "has geometry" .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> ;
                                               rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                               rdfs:label "in scheme" .


###  https://schema.org/address
<https://schema.org/address> rdf:type owl:ObjectProperty ;
                             rdfs:domain :CollectionPoint ,
                                         :WasteContainer ,
                                         :WasteFacility ;
                             rdfs:range <https://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> ;
                             rdfs:label "address" .


###  https://schema.org/contactPoint
<https://schema.org/contactPoint> rdf:type owl:ObjectProperty ;
                                  rdfs:domain :CollectionPoint ,
                                              :WasteFacility ;
                                  rdfs:range <https://schema.org/ContactPoint> ;
                                  rdfs:label "contact point" .


###  https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#perteneceAProvincia
<https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#perteneceAProvincia> rdf:type owl:ObjectProperty ;
                                                                                              rdfs:domain <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                              rdfs:range <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia> ;
                                                                                              rdfs:label "pertenece a provincia" .


###  https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#perteneceAlMunicipio
<https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#perteneceAlMunicipio> rdf:type owl:ObjectProperty ;
                                                                                               rdfs:domain <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio> ,
                                                                                                           <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito> ;
                                                                                               rdfs:range <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                               rdfs:label "pertenece al municipio" .


###  https://w3id.org/def/medioambiente/residuos#acceptsWasteType
:acceptsWasteType rdf:type owl:ObjectProperty ;
                  rdfs:domain :CollectionPoint ,
                              :WasteContainer ;
                  rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                  rdfs:label "accepts waste type" .


###  https://w3id.org/def/medioambiente/residuos#belongsTo
:belongsTo rdf:type owl:ObjectProperty ;
           rdfs:domain :CollectionPoint ,
                       :WasteContainer ,
                       :WasteFacility ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio>
                                      <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito>
                                      <https://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio>
                                    )
                      ] ;
           rdfs:label "belongs to" .


###  https://w3id.org/def/medioambiente/residuos#hasManagementScope
:hasManagementScope rdf:type owl:ObjectProperty ;
                    rdfs:domain :WasteFacility ;
                    rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                    rdfs:label "has management scope" .


###  https://w3id.org/def/medioambiente/residuos#hasTreatmentProcess
:hasTreatmentProcess rdf:type owl:ObjectProperty ;
                     rdfs:domain :WasteFacility ;
                     rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                     rdfs:label "has treatment process" .


###  https://w3id.org/def/medioambiente/residuos#managesWasteType
:managesWasteType rdf:type owl:ObjectProperty ;
                  rdfs:domain :WasteFacility ;
                  rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                  rdfs:label "manages waste type" .


