<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/def/medioambiente/residuos#"
     xml:base="https://w3id.org/def/medioambiente/residuos"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/def/medioambiente/residuos#">
        <owl:versionIRI rdf:resource="https://w3id.org/def/medioambiente/residuos/0.1.1"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-01</terms:created>
        <terms:creator>Laura Gilgado Romero</terms:creator>
        <terms:description xml:lang="en">Ontology that describes the elements associated with waste management, including facilities, containers and collection points.</terms:description>
        <terms:description xml:lang="es">Ontología que describe los elementos asociados a la gestión de residuos, incluyendo centros, contenedores y puntos limpios.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Ontology for the representation of waste management</terms:title>
        <terms:title xml:lang="es">Ontología para la representación de la gestión de residuos</terms:title>
        <vann:preferredNamespacePrefix>waste</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://w3id.org/def/medioambiente/residuos#"/>
        <owl:versionInfo>0.1.1</owl:versionInfo>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


